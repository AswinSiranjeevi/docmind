# Copy this to .env and add your key
# cp .env.example .env

# ── Required ──────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY= api_key
# ── Optional (defaults shown) ──────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5
